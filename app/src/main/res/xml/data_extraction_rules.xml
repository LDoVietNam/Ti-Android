<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" path="logs/" />
        <exclude domain="database" path="events.db" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" />
        <include domain="database" path="tasks.db" />
    </device-transfer>
</data-extraction-rules>
